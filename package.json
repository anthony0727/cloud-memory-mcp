{
  "name": "cloud-memory-mcp",
  "version": "0.1.0",
  "description": "Agent-agnostic persistent memory for AI assistants, backed by your own Google Drive",
  "type": "module",
  "main": "./dist/server.js",
  "bin": {
    "cloud-memory-mcp": "dist/server.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "tsc --watch",
    "start": "node dist/server.js",
    "install-mcp": "node dist/server.js --install",
    "uninstall-mcp": "node dist/server.js --uninstall"
  },
  "keywords": [
    "mcp",
    "memory",
    "ai",
    "agent",
    "google-drive",
    "persistent-memory",
    "claude",
    "llm",
    "model-context-protocol"
  ],
  "author": "jwseok0727",
  "repository": {
    "type": "git",
    "url": "https://github.com/jwseok0727/cloud-memory-mcp"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@octokit/rest": "^21.1.1",
    "googleapis": "^148.0.0",
    "open": "^10.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.6",
    "typescript": "^5.7.3"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.11.0"
  }
}
